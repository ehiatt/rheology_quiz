# Keep web sources as LF so the app diffs cleanly across machines
*.html text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf

# Any heavy binaries that ever land in the repo go through LFS
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text

# Icons are small — track them normally, just mark them binary
*.png  binary
*.ico  binary
